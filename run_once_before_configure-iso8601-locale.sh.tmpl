#!/bin/bash
{{- if eq .chezmoi.os "linux" }}

# Configure ISO 8601 locale (en_DK.UTF-8) for consistent date/time formatting

echo "Checking ISO 8601 locale configuration..."

# Check if en_DK.UTF-8 is already available
if locale -a | grep -q "en_DK.utf8"; then
    echo "✓ en_DK.UTF-8 locale already available"
    exit 0
fi

echo "Generating en_DK.UTF-8 locale for ISO 8601 timestamps..."

# Enable en_DK.UTF-8 in locale.gen
if [ -f /etc/locale.gen ]; then
    sudo sed -i 's/^#en_DK.UTF-8 UTF-8/en_DK.UTF-8 UTF-8/' /etc/locale.gen

    # Generate locales
    sudo locale-gen

    echo "✓ ISO 8601 locale configured"
else
    echo "⚠ Warning: /etc/locale.gen not found. You may need to configure locales manually."
    exit 1
fi

{{- else }}
echo "Skipping ISO 8601 locale configuration on non-Linux system"
{{- end }}
