# Common taps for all platforms
tap "aws/tap"
tap "hashicorp/tap"

{{- if eq .chezmoi.os "darwin" }}
# macOS-only taps
tap "robotsandpencils/made"
tap "xcodesorg/made"
{{- end }}

# Core packages (available on both macOS and Linux)
brew "aria2"
brew "aws-shell"
brew "awscli"
brew "bash-completion"
brew "brew-gem"
brew "libtool"
brew "cfssl"
brew "cheat"
brew "cmake"
brew "coreutils"
brew "curl"
brew "direnv"

{{- if eq .chezmoi.os "darwin" }}
brew "duti"  # macOS default applications manager
{{- end }}

brew "expect"
brew "fd"
brew "fzf"
brew "gd"
brew "gh"
brew "gnu-tar"
brew "go"
brew "grep"
brew "gts"
brew "ipcalc"
brew "ispell"
brew "jq"
brew "libmetalink"
brew "libvterm"
brew "libxext"
brew "libxrender"
brew "luajit-openresty"
brew "lzo"

{{- if eq .chezmoi.os "darwin" }}
brew "mas"  # Mac App Store CLI
{{- end }}

brew "neovim"
brew "nghttp2"
brew "node"
brew "p7zip"
brew "pandoc"
brew "pipenv"
brew "starship"
brew "pyenv-virtualenv"
brew "python-tabulate"
brew "rename"
brew "ripgrep"
brew "shellcheck"
brew "stow"
brew "subversion"
brew "tmux"
brew "tree"
brew "wget"
brew "zlib"
brew "zsh"
brew "zsh-completions"
brew "nushell"
brew "typst"
brew "hashicorp/tap/terraform"

{{- if eq .chezmoi.os "darwin" }}
# macOS-only GUI applications and tools
cask "wezterm"
brew "xcodesorg/made/xcodes"
cask "brave-browser"
cask "firefox"

