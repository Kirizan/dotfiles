#!/bin/bash
# Fix USB issues specific to the mimir desktop:
# 1. Disable autosuspend on GenesysLogic USB hubs to prevent hub chain resets
#    that disconnect downstream devices (Logitech receivers, keyboards, etc.)
# 2. Disable USB 3.0 port 2 where a USB 2.1 hub causes constant "Cannot enable"
#    enumeration spam (the hub works fine on the USB 2.0 side)

{{- if and (eq .chezmoi.os "linux") (eq .chezmoi.hostname "mimir") }}

set -e

echo "Applying USB fixes for mimir..."

# --- Fix 1: Disable autosuspend for GenesysLogic USB hubs ---
UDEV_RULE="/etc/udev/rules.d/90-usb-fixes.rules"

if [ -f "$UDEV_RULE" ] && grep -q "05e3" "$UDEV_RULE"; then
    echo "udev rule for GenesysLogic hubs already exists"
else
    echo "Creating udev rule to disable autosuspend on GenesysLogic USB hubs..."
    sudo tee "$UDEV_RULE" > /dev/null << 'EOF'
# Disable autosuspend for GenesysLogic USB 2.1 Hubs (05e3:0610)
# Prevents hub chain resets that disconnect downstream devices (Logitech receivers, etc.)
# Generated by chezmoi dotfiles
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="05e3", ATTR{idProduct}=="0610", TEST=="power/control", ATTR{power/control}="on"

# Also disable autosuspend for GenesysLogic USB 3.0 Hubs (05e3:0626)
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="05e3", ATTR{idProduct}=="0626", TEST=="power/control", ATTR{power/control}="on"
EOF
    sudo udevadm control --reload-rules
    echo "udev rule created and loaded"
fi

# --- Fix 2: Disable USB 3.0 port 2 enumeration spam ---
SERVICE_FILE="/etc/systemd/system/disable-usb2-port2.service"

if [ -f "$SERVICE_FILE" ]; then
    echo "systemd service for USB 3.0 port 2 disable already exists"
else
    echo "Creating systemd service to disable USB 3.0 port 2..."
    sudo tee "$SERVICE_FILE" > /dev/null << 'EOF'
[Unit]
Description=Disable USB 3.0 port 2 (no USB 3.0 device, prevents enumeration spam)
After=sys-bus-usb-devices-usb2.device

[Service]
Type=oneshot
ExecStart=/bin/bash -c 'echo 1 > /sys/bus/usb/devices/usb2/2-0:1.0/usb2-port2/disable'
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
EOF
    sudo systemctl daemon-reload
    sudo systemctl enable disable-usb2-port2.service
    echo "systemd service created and enabled"
fi

echo "USB fixes for mimir applied."

{{- else }}
echo "Skipping mimir USB fixes (not applicable on this system)"
{{- end }}
