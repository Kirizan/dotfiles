#!/usr/bin/env python3
"""
Patches NVIDIA Sync's tray popup positioning on Wayland.

On Wayland, Electron's tray.getBounds() returns {0,0,0,0} because the
StatusNotifierItem protocol doesn't expose icon coordinates. NVIDIA Sync
falls back to placing its popup at the top-right of the first display,
which is wrong on multi-monitor setups.

This script connects to NVIDIA Sync's Node.js inspector and monkey-patches
the BrowserWindow's setBounds/setPosition methods to always place the popup
at the bottom-right of the primary display, just above the panel.
"""

import http.client
import json
import sys
import time

INSPECT_PORT = 9229
PANEL_HEIGHT = 46
MARGIN = 10
MAX_RETRIES = 30  # wait up to 30 seconds for inspector


def get_ws_url():
    """Get the WebSocket debugger URL from the inspector HTTP endpoint."""
    conn = http.client.HTTPConnection("127.0.0.1", INSPECT_PORT, timeout=2)
    conn.request("GET", "/json")
    resp = conn.getresponse()
    targets = json.loads(resp.read())
    conn.close()
    for t in targets:
        if t.get("type") == "node":
            return t["webSocketDebuggerUrl"]
    return None


def wait_for_inspector():
    """Wait for the Node.js inspector to become available."""
    for i in range(MAX_RETRIES):
        try:
            url = get_ws_url()
            if url:
                return url
        except (ConnectionRefusedError, OSError, http.client.HTTPException):
            pass
        time.sleep(1)
    return None


def apply_patch(ws_url):
    """Connect to the inspector and inject the position fix."""
    import asyncio

    try:
        import websockets
    except ImportError:
        import subprocess
        subprocess.check_call(
            [sys.executable, "-m", "pip", "install", "--user",
             "--break-system-packages", "-q", "websockets"]
        )
        import websockets

    patch_js = r"""
    (function() {
        var electron = process.mainModule.require('electron');
        var BW = electron.BrowserWindow;
        var screen = electron.screen;
        var win = BW.getAllWindows()[0];
        if (!win) return JSON.stringify({error: 'no window found'});
        if (win.__positionPatched) return JSON.stringify({status: 'already patched'});

        var PANEL_HEIGHT = """ + str(PANEL_HEIGHT) + r""";
        var MARGIN = """ + str(MARGIN) + r""";

        var origSetBounds = win.setBounds.bind(win);
        var origSetPosition = win.setPosition.bind(win);

        function getCorrectedPosition(width, height) {
            var primary = screen.getPrimaryDisplay();
            var x = primary.bounds.x + primary.bounds.width - width - MARGIN;
            var y = primary.bounds.y + primary.bounds.height - PANEL_HEIGHT - height - MARGIN;
            return {x: x, y: y};
        }

        win.setBounds = function(bounds, animate) {
            var pos = getCorrectedPosition(
                bounds.width || win.getBounds().width,
                bounds.height || win.getBounds().height
            );
            bounds.x = pos.x;
            bounds.y = pos.y;
            return origSetBounds(bounds, animate);
        };

        win.setPosition = function(x, y, animate) {
            var b = win.getBounds();
            var pos = getCorrectedPosition(b.width, b.height);
            return origSetPosition(pos.x, pos.y, animate);
        };

        win.on('show', function() {
            setTimeout(function() {
                var b = win.getBounds();
                var pos = getCorrectedPosition(b.width, b.height);
                origSetBounds({x: pos.x, y: pos.y, width: b.width, height: b.height});
            }, 50);
        });

        // Apply immediately
        var b = win.getBounds();
        var pos = getCorrectedPosition(b.width, b.height);
        origSetBounds({x: pos.x, y: pos.y, width: b.width, height: b.height});

        win.__positionPatched = true;
        return JSON.stringify({status: 'patched', position: pos});
    })()
    """

    async def run():
        async with websockets.connect(ws_url, max_size=None) as ws:
            await ws.send(json.dumps({"id": 1, "method": "Runtime.enable"}))
            # Drain initial messages
            while True:
                try:
                    await asyncio.wait_for(ws.recv(), timeout=2.0)
                except asyncio.TimeoutError:
                    break

            await ws.send(json.dumps({
                "id": 10,
                "method": "Runtime.evaluate",
                "params": {"expression": patch_js, "returnByValue": True}
            }))

            while True:
                msg = await asyncio.wait_for(ws.recv(), timeout=5.0)
                data = json.loads(msg)
                if data.get("id") == 10:
                    result = data.get("result", {}).get("result", {})
                    val = result.get("value", result.get("description", ""))
                    return val

    return asyncio.run(run())


def main():
    ws_url = wait_for_inspector()
    if not ws_url:
        print("nvidia-sync-fix-position: inspector not available, giving up",
              file=sys.stderr)
        sys.exit(1)

    # Give the app a moment to create its window
    time.sleep(2)

    result = apply_patch(ws_url)
    print(f"nvidia-sync-fix-position: {result}")


if __name__ == "__main__":
    main()
