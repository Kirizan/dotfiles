{{- if .isDGXSpark -}}
#!/bin/bash
# Configure CUDA environment for NVIDIA DGX Spark
# The DGX Spark ships with CUDA 13.0+ pre-installed but the shell
# environment variables are not configured by default.
# This creates a system-wide profile.d script so CUDA is available
# in all contexts (interactive shells, poetry run, cron, etc.)

set -e

CUDA_DIR="/usr/local/cuda"
PROFILE_SCRIPT="/etc/profile.d/cuda.sh"

# Verify CUDA toolkit is present
if [ ! -d "$CUDA_DIR" ]; then
    echo "⚠ CUDA directory $CUDA_DIR not found on DGX Spark"
    echo "  This is unexpected — the DGX Spark should ship with CUDA pre-installed."
    echo "  Check that the CUDA toolkit package is installed."
    exit 1
fi

echo "Configuring system-wide CUDA environment for DGX Spark..."

# Create /etc/profile.d/cuda.sh for system-wide CUDA env
if [ ! -f "$PROFILE_SCRIPT" ]; then
    echo "Creating $PROFILE_SCRIPT..."
    sudo tee "$PROFILE_SCRIPT" > /dev/null <<'CUDA_EOF'
# CUDA toolkit environment (auto-configured by chezmoi for DGX Spark)
if [ -d "/usr/local/cuda" ]; then
  export CUDA_HOME="/usr/local/cuda"
  export PATH="$CUDA_HOME/bin:$PATH"
  export LD_LIBRARY_PATH="$CUDA_HOME/lib64${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
fi
CUDA_EOF
    sudo chmod 644 "$PROFILE_SCRIPT"
    echo "✓ Created $PROFILE_SCRIPT"
else
    echo "✓ $PROFILE_SCRIPT already exists"
fi

# Verify nvcc is accessible
if [ -x "$CUDA_DIR/bin/nvcc" ]; then
    CUDA_VERSION=$("$CUDA_DIR/bin/nvcc" --version | grep "release" | sed 's/.*release //' | sed 's/,.*//')
    echo "✓ CUDA $CUDA_VERSION toolkit verified at $CUDA_DIR"
else
    echo "⚠ nvcc not found at $CUDA_DIR/bin/nvcc"
    echo "  The CUDA toolkit may be incomplete."
fi
{{- end }}
