#!/bin/bash
# This script installs essential packages on the system

# Set askpass for sudo if available
{{- if eq .chezmoi.os "linux" }}
if [ -f "/usr/bin/lxqt-openssh-askpass" ]; then
  export SUDO_ASKPASS="/usr/bin/lxqt-openssh-askpass"
fi
{{- end }}

{{- if eq .chezmoi.os "darwin" }}
# macOS: Use Homebrew bundle to install from Brewfile
if ! command -v brew &> /dev/null; then
    echo "Homebrew not found. Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

echo "Installing packages from Brewfile..."
brew bundle --file="{{ .chezmoi.sourceDir }}/Brewfile"

# Install eza (modern ls with git support)
echo "Installing eza..."
brew install eza

{{- else if eq .chezmoi.osRelease.id "arch" }}
# Arch Linux: Install equivalent packages using pacman
echo "Installing essential packages on Arch Linux..."

# Install base-devel group (includes make, gcc, etc.)
if ! pacman -Qg base-devel &> /dev/null; then
    echo "Installing base-devel group..."
    sudo pacman -S --needed --noconfirm base-devel
fi

# Core development tools and utilities
PACKAGES=(
    # Basic utilities often missing in minimal installations
    which
    findutils
    grep
    sed
    gawk
    diffutils
    gnu-tar
    gzip
    unzip
    procps-ng
    util-linux
    coreutils

    # Development essentials
    git
    make
    cmake
    curl
    wget

    # Shell and completion
    bash-completion
    zsh
    zsh-completions

    # Modern CLI tools
    aria2
    aws-cli
    direnv
    expect
    eza
    fd
    fzf
    gh
    jq
    ripgrep
    shellcheck
    starship
    stow
    tree
    tmux

    # Programming languages and tools
    go
    nodejs
    npm
    pipenv
    python-pipx
    python-pyenv
    python-tabulate

    # Additional tools
    neovim
    p7zip
    pandoc
    subversion
    zlib
    terraform
    nushell
    typst
{{- if not .isWSL }}
    # GUI applications (skip on WSL)
    firefox
    # Nerd Fonts (GUI-only)
    ttf-0xproto-nerd
    ttf-3270-nerd
    ttf-agave-nerd
    ttf-anonymouspro-nerd
    ttf-arimo-nerd
    ttf-aurulentsansmono-nerd
    ttf-bigblueterminal-nerd
    ttf-bitstreamverasansmono-nerd
    ttf-cascadiacode-nerd
    ttf-cascadiamono-nerd
    ttf-codenewroman-nerd
    ttf-cousine-nerd
    ttf-d2coding-nerd
    ttf-daddytimemono-nerd
    ttf-dejavu-nerd
    ttf-departuremono-nerd
    ttf-droid-nerd
    ttf-envycodear-nerd
    ttf-fantasquesansmono-nerd
    ttf-firacode-nerd
    ttf-firamono-nerd
    ttf-geist-mono-nerd
    ttf-go-nerd
    ttf-hack-nerd
    ttf-hasklig-nerd
    ttf-heavydata-nerd
    ttf-iawriter-nerd
    ttf-ibmplex-mono-nerd
    ttf-inconsolata-go-nerd
    ttf-inconsolata-lgc-nerd
    ttf-inconsolata-nerd
    ttf-intone-nerd
    ttf-iosevka-nerd
    ttf-iosevkaterm-nerd
    ttf-iosevkatermslab-nerd
    ttf-jetbrains-mono-nerd
    ttf-lekton-nerd
    ttf-liberation-mono-nerd
    ttf-lilex-nerd
    ttf-martianmono-nerd
    ttf-meslo-nerd
    ttf-monaspace-nerd
    ttf-monocraft-nerd
    ttf-monofur-nerd
    ttf-monoid-nerd
    ttf-mononoki-nerd
    ttf-noto-nerd
    ttf-opendyslexic-nerd
    ttf-overpass-nerd
    ttf-profont-nerd
    ttf-proggyclean-nerd
    ttf-recursive-nerd
    ttf-roboto-mono-nerd
    ttf-sourcecodepro-nerd
    ttf-spacemono-nerd
    ttf-terminus-nerd
    ttf-tinos-nerd
    ttf-ubuntu-mono-nerd
    ttf-ubuntu-nerd
    ttf-ubuntu-sans-nerd
    ttf-victormono-nerd
{{- end }}
    # Powerlevel10k theme
    zsh-theme-powerlevel10k
)

for pkg in "${PACKAGES[@]}"; do
    if ! pacman -Qi "$pkg" &> /dev/null; then
        echo "Installing $pkg..."
        sudo pacman -S --needed --noconfirm "$pkg" || echo "Warning: Failed to install $pkg"
    fi
done

# Install AUR packages using yay
AUR_PACKAGES=(
    brave-bin
    wezterm-nightly-bin
)

# Check if yay is installed, install it if not
if ! command -v yay &> /dev/null; then
    echo "Installing yay AUR helper..."
    sudo pacman -S --needed --noconfirm base-devel git
    git clone https://aur.archlinux.org/yay.git /tmp/yay
    cd /tmp/yay
    makepkg -si --noconfirm
    cd -
    rm -rf /tmp/yay
fi

for pkg in "${AUR_PACKAGES[@]}"; do
    if ! pacman -Qi "$pkg" &> /dev/null; then
        echo "Installing AUR package $pkg..."
        yay -S --needed --noconfirm "$pkg" || echo "Warning: Failed to install $pkg"
    fi
done

echo "Package installation complete!"

{{- else if or (eq .chezmoi.osRelease.id "ubuntu") (eq .chezmoi.osRelease.id "debian") }}
# Ubuntu/Debian: Install equivalent packages using apt
echo "Installing essential packages on Ubuntu/Debian..."

# Update package list
sudo apt-get update

# Install build-essential (includes make, gcc, etc.)
if ! dpkg -l build-essential &> /dev/null; then
    echo "Installing build-essential..."
    sudo apt-get install -y build-essential
fi

# Core utilities and development tools
PACKAGES=(
    # Basic utilities often missing in minimal WSL installations
    which
    findutils
    grep
    sed
    gawk
    diffutils
    tar
    gzip
    unzip
    procps
    util-linux
    coreutils

    # Development essentials
    git
    make
    cmake
    curl
    wget
    pkg-config

    # Shell and completion
    bash-completion
    zsh

    # Modern CLI tools
    direnv
    expect
    fd-find
    fzf
    jq
    ripgrep
    tree
    tmux
    stow

    # Programming languages and tools
    golang
    nodejs
    npm
    python3-pip
    python3-venv
    pipenv

    # Additional tools
    neovim
    p7zip-full
    pandoc
    shellcheck
    subversion
    zlib1g-dev
    software-properties-common
)

for pkg in "${PACKAGES[@]}"; do
    if ! dpkg -l "$pkg" &> /dev/null; then
        echo "Installing $pkg..."
        sudo apt-get install -y "$pkg" || echo "Warning: Failed to install $pkg"
    fi
done

# Install starship prompt (not in repos, use install script)
if ! command -v starship &> /dev/null; then
    echo "Installing starship..."
    curl -sS https://starship.rs/install.sh | sh -s -- -y
fi

# Install eza (modern ls) via cargo if available
if ! command -v eza &> /dev/null; then
    if command -v cargo &> /dev/null; then
        echo "Installing eza..."
        cargo install eza
    else
        echo "Warning: cargo not found, skipping eza installation"
    fi
fi

# Install nushell (may need to use cargo or add repo)
if ! command -v nu &> /dev/null; then
    if command -v cargo &> /dev/null; then
        echo "Installing nushell..."
        cargo install nu
    else
        echo "Warning: nushell not available, install manually or use cargo"
    fi
fi

# Install typst (modern typesetting system)
if ! command -v typst &> /dev/null; then
    if command -v cargo &> /dev/null; then
        echo "Installing typst..."
        cargo install typst-cli
    else
        echo "Warning: typst not available, install manually or use cargo"
    fi
fi

echo "Package installation complete!"

{{- else if or (eq .chezmoi.osRelease.id "centos") (eq .chezmoi.osRelease.id "rhel") }}
# CentOS/RHEL: Install equivalent packages using dnf
echo "Installing essential packages on CentOS/RHEL..."

# Enable EPEL repository for additional packages
if ! rpm -q epel-release &> /dev/null; then
    echo "Installing EPEL repository..."
    sudo dnf install -y epel-release
fi

# Install Development Tools group (includes make, gcc, etc.)
if ! dnf group list installed | grep -q "Development Tools"; then
    echo "Installing Development Tools group..."
    sudo dnf groupinstall -y "Development Tools"
fi

# Core utilities and development tools
PACKAGES=(
    # Basic utilities often missing in minimal WSL installations
    which
    findutils
    grep
    sed
    gawk
    diffutils
    tar
    gzip
    unzip
    procps-ng
    util-linux
    coreutils

    # Development essentials
    git
    make
    cmake
    curl
    wget

    # Shell and completion
    bash-completion
    zsh

    # Modern CLI tools
    direnv
    expect
    fd-find
    fzf
    jq
    ripgrep
    tree
    tmux
    stow

    # Programming languages and tools
    golang
    nodejs
    npm
    python3-pip
    python3-pipenv

    # Additional tools
    neovim
    p7zip
    pandoc
    ShellCheck
    subversion
    zlib-devel
    terraform
    nushell
    typst
)

for pkg in "${PACKAGES[@]}"; do
    if ! rpm -q "$pkg" &> /dev/null; then
        echo "Installing $pkg..."
        sudo dnf install -y "$pkg" || echo "Warning: Failed to install $pkg"
    fi
done

# Install starship prompt (not in repos, use install script)
if ! command -v starship &> /dev/null; then
    echo "Installing starship..."
    curl -sS https://starship.rs/install.sh | sh -s -- -y
fi

# Install eza (modern ls) via cargo if not available
if ! command -v eza &> /dev/null; then
    echo "Installing eza..."
    if command -v cargo &> /dev/null; then
        cargo install eza
    else
        echo "Warning: cargo not found, skipping eza installation"
    fi
fi

# Install typst via cargo if not available in repos
if ! command -v typst &> /dev/null; then
    echo "Installing typst..."
    if command -v cargo &> /dev/null; then
        cargo install typst-cli
    else
        echo "Warning: cargo not found, skipping typst installation"
    fi
fi

echo "Package installation complete!"

{{- else if eq .chezmoi.os "windows" }}
# Windows: Use winget package manager
echo "Installing essential packages on Windows..."

# Core development tools and utilities
winget install --id Git.Git -e --source winget
winget install --id Neovim.Neovim -e --source winget
winget install --id JanDeDobbeleer.OhMyPosh -e --source winget  # Alternative to starship
winget install --id Microsoft.PowerShell -e --source winget
winget install --id Nushell.Nushell -e --source winget
winget install --id wez.wezterm -e --source winget
winget install --id Microsoft.VisualStudioCode -e --source winget
winget install --id OpenJS.NodeJS -e --source winget
winget install --id Python.Python.3.12 -e --source winget
winget install --id GoLang.Go -e --source winget
winget install --id BurntSushi.ripgrep.MSVC -e --source winget
winget install --id sharkdp.fd -e --source winget
winget install --id junegunn.fzf -e --source winget
winget install --id jqlang.jq -e --source winget
winget install --id HashiCorp.Terraform -e --source winget

# Install typst (modern typesetting system)
echo "Installing typst..."
winget install --id typst.typst -e --source winget

# Install starship prompt
echo "Installing starship..."
winget install --id Starship.Starship -e --source winget

# Install eza (modern ls) via cargo if available
if (Get-Command cargo -ErrorAction SilentlyContinue) {
    echo "Installing eza..."
    cargo install eza
}

echo "Package installation complete!"
echo "Note: You may need to restart your terminal for changes to take effect."

{{- else }}
echo "Unsupported operating system. Please install packages manually."
exit 1
{{- end }}
