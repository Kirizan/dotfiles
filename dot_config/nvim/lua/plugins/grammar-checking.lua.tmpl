return {
  -- ltex_extra.nvim - Proper client-side handlers for ltex-ls
  -- Implements addToDictionary, disableRules, hideFalsePositives
  {
    "barreiroleo/ltex_extra.nvim",
    ft = { "typst", "markdown", "text", "tex", "gitcommit", "rst" },
    dependencies = { "neovim/nvim-lspconfig" },
  },

  -- LTeX-LS - LanguageTool grammar and spell checking via LSP
  -- Always enabled (works on both personal and work machines)
  {
    "neovim/nvim-lspconfig",
    dependencies = { "barreiroleo/ltex_extra.nvim" },
    opts = function(_, opts)
      opts.servers = opts.servers or {}
      opts.servers.ltex = {
        enabled = true,
        autostart = true,
        filetypes = { "typst", "markdown", "text", "tex", "gitcommit", "rst" },
        settings = {
          ltex = {
            language = "en-US",
            checkFrequency = "save", -- Check on save, not real-time (less intrusive)
            diagnosticSeverity = "information",
            -- Disable specific rules if needed
            -- disabledRules = {},
            -- additionalRules = {
            --   enablePickyRules = true,
            -- },
          },
        },
      }

      -- Setup ltex_extra when ltex attaches (LazyVim method)
      opts.setup = opts.setup or {}
      opts.setup.ltex = function(_, _)
        vim.api.nvim_create_autocmd("LspAttach", {
          callback = function(args)
            local client = vim.lsp.get_client_by_id(args.data.client_id)
            if client and client.name == "ltex" then
              -- Disable progress notifications from LTeX
              client.server_capabilities.window = client.server_capabilities.window or {}
              client.server_capabilities.window.workDoneProgress = false

              require("ltex_extra").setup({
                load_langs = { "en-US" }, -- Languages to load
                init_check = true, -- Check when ltex starts
                path = vim.fn.stdpath("config") .. "/ltex", -- Dictionary storage
                log_level = "none", -- Set to "debug" if troubleshooting
              })
            end
          end,
        })
      end

      return opts
    end,
  },

  -- Mason: Ensure ltex-ls is installed
  {
    "mason-org/mason.nvim",
    opts = function(_, opts)
      opts.ensure_installed = opts.ensure_installed or {}
      table.insert(opts.ensure_installed, "ltex-ls")
{{- if eq .profile "personal" }}
      -- Grammarly only on personal machines
      table.insert(opts.ensure_installed, "grammarly-languageserver")
{{- end }}
      return opts
    end,
  },

{{- if eq .profile "personal" }}
  -- Grammarly LSP - Only on personal machines
  -- Never autostarts - manual start only via :GrammarlyStart
  {
    "neovim/nvim-lspconfig",
    opts = function(_, opts)
      opts.servers = opts.servers or {}

      -- Store Grammarly auth URL globally
      _G.grammarly_auth_url = nil

      opts.servers.grammarly = {
        autostart = false, -- NEVER autostart - manual only
        filetypes = {}, -- Empty filetypes list prevents autostart on any filetype
        init_options = {
          clientId = "client_BaDkMgx4X19X9UxxYRCXZo",
        },
        handlers = {
          -- Capture authentication URL from Grammarly messages
          ["window/showMessage"] = function(err, result, ctx, config)
            if result and result.message then
              local url = result.message:match("(https://[^%s]+)")
              if url and url:match("grammarly") then
                _G.grammarly_auth_url = url
                vim.notify(
                  "Grammarly authentication URL captured.\nRun :GrammarlyAuthenticate to open it",
                  vim.log.levels.INFO
                )
              end
            end
            -- Call default handler
            return vim.lsp.handlers["window/showMessage"](err, result, ctx, config)
          end,
        },
        on_attach = function(client, bufnr)
          vim.notify("Grammarly attached. Use :GrammarlyAuthenticate if auth needed", vim.log.levels.INFO)
        end,
      }
      return opts
    end,
  },
{{- end }}

  -- Keybindings and commands for grammar checking
  {
    "LazyVim/LazyVim",
    opts = function()
      -- Code quality keybindings: LSP, spelling, grammar, diagnostics
      -- <leader>kc namespace - works with LTeX-LS and other LSPs

      -- <leader>kca - Show available fixes (code actions)
      vim.keymap.set("n", "<leader>kca", vim.lsp.buf.code_action, { desc = "Code Actions / Fixes" })

      -- <leader>kcl - List all issues
      vim.keymap.set("n", "<leader>kcl", vim.diagnostic.setloclist, { desc = "List All Issues" })

      -- <leader>kcn - Next issue
      vim.keymap.set("n", "<leader>kcn", vim.diagnostic.goto_next, { desc = "Next Issue" })

      -- <leader>kcp - Previous issue
      vim.keymap.set("n", "<leader>kcp", vim.diagnostic.goto_prev, { desc = "Previous Issue" })

      -- <leader>kch - Show issue details (hover)
      vim.keymap.set("n", "<leader>kch", vim.diagnostic.open_float, { desc = "Show Issue Details" })

      -- <leader>kci - Show info about current diagnostic
      vim.keymap.set("n", "<leader>kci", function()
        local diagnostics = vim.diagnostic.get(0, { lnum = vim.fn.line(".") - 1 })
        if #diagnostics > 0 then
          local diag = diagnostics[1]
          local source = diag.source or "Unknown"
          local severity = vim.diagnostic.severity[diag.severity] or "Unknown"
          vim.notify(
            string.format("Source: %s\nSeverity: %s\nMessage: %s", source, severity, diag.message),
            vim.log.levels.INFO
          )
        else
          vim.notify("No diagnostic at cursor", vim.log.levels.INFO)
        end
      end, { desc = "Diagnostic Info" })

      -- <leader>kcr - Refresh checks
      vim.keymap.set("n", "<leader>kcr", function()
        -- Force buffer update to trigger LSP re-check
        vim.cmd("write")
        vim.notify("Checks refreshed", vim.log.levels.INFO)
      end, { desc = "Refresh Checks" })

      -- <leader>kcR - Restart LSP
      vim.keymap.set("n", "<leader>kcR", function()
        local clients = vim.lsp.get_clients({ bufnr = 0, name = "ltex" })
        if #clients > 0 then
          for _, client in ipairs(clients) do
            vim.lsp.stop_client(client.id, true)
          end
          vim.defer_fn(function()
            vim.cmd("edit") -- Reload buffer to restart LSP
            vim.notify("LTeX-LS restarted", vim.log.levels.INFO)
          end, 100)
        else
          vim.notify("LTeX-LS not running", vim.log.levels.WARN)
        end
      end, { desc = "Restart LSP" })

      -- <leader>kct - Toggle live checking (edit) vs check-on-save
      vim.keymap.set("n", "<leader>kct", function()
        local clients = vim.lsp.get_clients({ bufnr = 0, name = "ltex" })
        if #clients == 0 then
          vim.notify("LTeX-LS not running", vim.log.levels.WARN)
          return
        end

        for _, client in ipairs(clients) do
          local current_mode = client.config.settings.ltex.checkFrequency or "save"
          local new_mode = current_mode == "save" and "edit" or "save"

          -- Update client settings
          client.config.settings.ltex.checkFrequency = new_mode
          client.notify("workspace/didChangeConfiguration", {
            settings = client.config.settings,
          })

          local mode_name = new_mode == "edit" and "Live Checking (while typing)" or "Check on Save"
          vim.notify("LTeX: " .. mode_name, vim.log.levels.INFO)
        end
      end, { desc = "Toggle Live Checking" })

{{- if eq .profile "personal" }}
      -- Grammarly control commands (personal machines only)
      vim.api.nvim_create_user_command("GrammarlyStart", function()
        local bufnr = vim.api.nvim_get_current_buf()
        local clients = vim.lsp.get_clients({ bufnr = bufnr, name = "grammarly" })

        if #clients > 0 then
          vim.notify("Grammarly already running", vim.log.levels.INFO)
        else
          -- Get current filetype
          local ft = vim.bo[bufnr].filetype
          local supported_fts = { "typst", "markdown", "text", "tex", "gitcommit" }

          -- Check if current filetype is supported
          local is_supported = false
          for _, supported_ft in ipairs(supported_fts) do
            if ft == supported_ft then
              is_supported = true
              break
            end
          end

          if not is_supported then
            vim.notify(
              string.format("Grammarly not recommended for filetype '%s'.\nSupported: typst, markdown, text, tex, gitcommit", ft),
              vim.log.levels.WARN
            )
            return
          end

          -- Start Grammarly
          vim.cmd("LspStart grammarly")
          vim.notify(
            "Grammarly starting...\nNeed to authenticate? Run :GrammarlyAuthenticate (<leader>kGa)",
            vim.log.levels.INFO,
            { timeout = 5000 }
          )
        end
      end, { desc = "Start Grammarly (current buffer)" })

      vim.api.nvim_create_user_command("GrammarlyStartProject", function()
        -- Start Grammarly for all buffers in current working directory
        vim.cmd("LspStart grammarly")
        vim.notify("Grammarly started (project-wide)", vim.log.levels.INFO)
      end, { desc = "Start Grammarly (project-wide)" })

      vim.api.nvim_create_user_command("GrammarlyStop", function()
        local bufnr = vim.api.nvim_get_current_buf()
        local clients = vim.lsp.get_clients({ bufnr = bufnr, name = "grammarly" })

        if #clients == 0 then
          vim.notify("Grammarly not running", vim.log.levels.WARN)
        else
          for _, client in ipairs(clients) do
            vim.lsp.stop_client(client.id, true)
          end
          vim.notify("Grammarly stopped", vim.log.levels.INFO)
        end
      end, { desc = "Stop Grammarly" })

      vim.api.nvim_create_user_command("GrammarlyToggle", function()
        local bufnr = vim.api.nvim_get_current_buf()
        local clients = vim.lsp.get_clients({ bufnr = bufnr, name = "grammarly" })

        if #clients > 0 then
          for _, client in ipairs(clients) do
            vim.lsp.stop_client(client.id, true)
          end
          vim.notify("Grammarly stopped", vim.log.levels.INFO)
        else
          vim.cmd("LspStart grammarly")
          vim.notify("Grammarly started", vim.log.levels.INFO)
        end
      end, { desc = "Toggle Grammarly" })

      vim.api.nvim_create_user_command("GrammarlyStatus", function()
        local bufnr = vim.api.nvim_get_current_buf()
        local clients = vim.lsp.get_clients({ bufnr = bufnr, name = "grammarly" })

        if #clients > 0 then
          vim.notify("Grammarly: Running (" .. #clients .. " client(s))", vim.log.levels.INFO)
        else
          vim.notify("Grammarly: Not running", vim.log.levels.INFO)
        end
      end, { desc = "Check Grammarly status" })

      vim.api.nvim_create_user_command("GrammarlyRestart", function()
        local bufnr = vim.api.nvim_get_current_buf()
        local clients = vim.lsp.get_clients({ bufnr = bufnr, name = "grammarly" })

        if #clients > 0 then
          for _, client in ipairs(clients) do
            vim.lsp.stop_client(client.id, true)
          end
          vim.defer_fn(function()
            vim.cmd("LspStart grammarly")
            vim.notify("Grammarly restarted", vim.log.levels.INFO)
          end, 500)
        else
          vim.notify("Grammarly not running. Use :GrammarlyStart first", vim.log.levels.WARN)
        end
      end, { desc = "Restart Grammarly (after auth)" })

      vim.api.nvim_create_user_command("GrammarlyAuthenticate", function()
        -- Helper function to open URL in browser (WSL-compatible)
        local function open_url(url)
          local is_wsl = vim.fn.system("grep -qi microsoft /proc/version 2>/dev/null && echo 1 || echo 0"):match("1") ~= nil

          if is_wsl then
            -- WSL: Try wslview first, fallback to explorer.exe
            if vim.fn.executable("wslview") == 1 then
              vim.fn.system({ "wslview", url })
            else
              vim.fn.system({ "explorer.exe", url })
            end
          elseif vim.fn.has("mac") == 1 then
            vim.fn.system({ "open", url })
          else
            vim.fn.system({ "xdg-open", url })
          end
        end

        -- Check if URL is already captured
        if _G.grammarly_auth_url then
          vim.notify("Opening Grammarly authentication URL...", vim.log.levels.INFO)
          open_url(_G.grammarly_auth_url)
          return
        end

        -- Check if Grammarly is running
        local bufnr = vim.api.nvim_get_current_buf()
        local clients = vim.lsp.get_clients({ bufnr = bufnr, name = "grammarly" })

        if #clients == 0 then
          -- Start Grammarly and wait for auth URL
          vim.notify("Starting Grammarly to capture authentication URL...", vim.log.levels.INFO)
          vim.cmd("LspStart grammarly")

          -- Wait for auth URL to be captured (max 10 seconds)
          local attempts = 0
          local max_attempts = 20 -- 20 * 500ms = 10 seconds

          local function check_auth_url()
            attempts = attempts + 1
            if _G.grammarly_auth_url then
              vim.notify("Authentication URL captured! Opening browser...", vim.log.levels.INFO)
              open_url(_G.grammarly_auth_url)
            elseif attempts < max_attempts then
              vim.defer_fn(check_auth_url, 500)
            else
              vim.notify(
                "Timeout waiting for auth URL.\nGrammarly might already be authenticated or not sending auth URL.\nCheck :LspInfo for status",
                vim.log.levels.WARN
              )
            end
          end

          vim.defer_fn(check_auth_url, 1000) -- Start checking after 1 second
        else
          vim.notify(
            "Grammarly already running.\nIf already authenticated, no URL will appear.\nCheck :LspInfo for status",
            vim.log.levels.INFO
          )
        end
      end, { desc = "Authenticate Grammarly (open OAuth URL)" })

      -- Grammarly keybindings
      vim.keymap.set("n", "<leader>kGe", "<cmd>GrammarlyStart<cr>", { desc = "Enable Grammarly" })
      vim.keymap.set("n", "<leader>kGd", "<cmd>GrammarlyStop<cr>", { desc = "Disable Grammarly" })
      vim.keymap.set("n", "<leader>kGt", "<cmd>GrammarlyToggle<cr>", { desc = "Toggle Grammarly" })
      vim.keymap.set("n", "<leader>kGs", "<cmd>GrammarlyStatus<cr>", { desc = "Status" })
      vim.keymap.set("n", "<leader>kGp", "<cmd>GrammarlyStartProject<cr>", { desc = "Enable (Project)" })
      vim.keymap.set("n", "<leader>kGa", "<cmd>GrammarlyAuthenticate<cr>", { desc = "Authenticate (open URL)" })
      vim.keymap.set("n", "<leader>kGr", "<cmd>GrammarlyRestart<cr>", { desc = "Restart" })
{{- else }}
      -- Work machine - no Grammarly available
      vim.keymap.set("n", "<leader>kGs", function()
        vim.notify("Grammarly not available on work machines", vim.log.levels.WARN)
      end, { desc = "Grammarly (Not Available)" })
{{- end }}
    end,
  },

  -- Configure which-key for code quality groups
  {
    "folke/which-key.nvim",
    optional = true,
    opts = {
      spec = {
        { "<leader>kc", group = "code (LSP/diagnostics)", icon = "" },
{{- if eq .profile "personal" }}
        { "<leader>kG", group = "grammarly", icon = "" },
{{- else }}
        { "<leader>kG", group = "grammarly (unavailable)", icon = "" },
{{- end }}
      },
    },
  },
}
