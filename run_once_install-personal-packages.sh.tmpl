#!/bin/bash
# Personal profile only - packages not needed on work systems
# Skipped on WSL (GUI apps not supported)

{{- if and (eq .profile "personal") (not .isWSL) (not .isHeadless) }}

echo "Installing personal profile packages..."

{{- if eq .chezmoi.os "darwin" }}
# macOS personal packages
if command -v brew &> /dev/null; then
    echo "Installing personal apps..."
    # Add personal apps here
    # brew install --cask discord
fi

{{- else if .isArchBased }}
# Arch-based Linux personal packages
echo "Installing personal packages on Arch-based Linux..."

PERSONAL_PACKAGES=(
    discord
    # Add more personal packages here
)

for pkg in "${PERSONAL_PACKAGES[@]}"; do
    if ! pacman -Qi "$pkg" &> /dev/null; then
        echo "Installing $pkg..."
        sudo pacman -S --needed --noconfirm "$pkg" || echo "Warning: Failed to install $pkg"
    else
        echo "$pkg is already installed"
    fi
done

echo "Personal package installation complete!"

{{- else }}
echo "Unsupported operating system for personal packages"
{{- end }}

{{- else }}
{{- if or .isWSL .isHeadless }}
echo "Skipping personal packages (no GUI on this system)"
{{- else }}
echo "Skipping personal packages (not on personal profile)"
{{- end }}
{{- end }}
