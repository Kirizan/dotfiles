#!/bin/bash
# Personal profile only - packages not needed on work systems
# Skipped on WSL (GUI apps not supported)

{{- if and (eq .profile "personal") (not .isWSL) (not .isHeadless) }}

echo "Installing personal profile packages..."

{{- if eq .chezmoi.os "darwin" }}
# macOS personal packages (most are in Brewfile, extras here)
if command -v brew &> /dev/null; then
    echo "Installing personal apps..."
    brew install --cask discord 2>/dev/null || true
    brew install --cask obsidian 2>/dev/null || true
fi

{{- else if .isArchBased }}
# Arch-based Linux personal packages
echo "Installing personal packages on Arch-based Linux..."

# Sync package databases to avoid 404 errors from stale mirrors
sudo pacman -Sy --noconfirm

PERSONAL_PACKAGES=(
    discord
    obsidian
)

for pkg in "${PERSONAL_PACKAGES[@]}"; do
    if ! pacman -Qi "$pkg" &> /dev/null; then
        echo "Installing $pkg..."
        sudo pacman -S --needed --noconfirm "$pkg" || echo "Warning: Failed to install $pkg"
    else
        echo "$pkg is already installed"
    fi
done

# Install NVIDIA Sync (DGX Spark remote access client) from AUR
AUR_PACKAGES=(
    nvidia-sync
    nvidia-sync-terminal-fix
    onlyoffice-bin
)

for pkg in "${AUR_PACKAGES[@]}"; do
    if ! pacman -Qi "$pkg" &> /dev/null; then
        echo "Installing $pkg..."
        if command -v paru &> /dev/null; then
            paru -S --needed --noconfirm "$pkg" || echo "Warning: Failed to install $pkg"
        elif command -v yay &> /dev/null; then
            yay -S --needed --noconfirm "$pkg" || echo "Warning: Failed to install $pkg"
        else
            echo "Warning: No AUR helper found. Install $pkg manually or install paru/yay first."
        fi
    else
        echo "$pkg is already installed"
    fi
done

echo "Personal package installation complete!"

{{- else if .isDebianBased }}
# Debian-based Linux personal packages
echo "Installing personal packages on Debian-based Linux..."

# Install Obsidian via snap (official distribution method for Ubuntu)
if ! command -v obsidian &> /dev/null && ! snap list obsidian &> /dev/null 2>&1; then
    echo "Installing Obsidian via snap..."
    sudo snap install obsidian --classic || echo "Warning: Failed to install Obsidian"
else
    echo "Obsidian is already installed"
fi

echo "Personal package installation complete!"

{{- else }}
echo "Unsupported operating system for personal packages"
{{- end }}

{{- else }}
{{- if or .isWSL .isHeadless }}
echo "Skipping personal packages (no GUI on this system)"
{{- else }}
echo "Skipping personal packages (not on personal profile)"
{{- end }}
{{- end }}
