{{- /* Detect WSL (Windows Subsystem for Linux) */ -}}
{{- $isWSL := false -}}
{{- if eq .chezmoi.os "linux" -}}
{{-   if or (contains "microsoft" (.chezmoi.kernel.osrelease | lower)) (contains "wsl" (.chezmoi.kernel.osrelease | lower)) -}}
{{-     $isWSL = true -}}
{{-   end -}}
{{- end -}}

{{- /* Determine profile: "work" or "personal" */ -}}
{{- $profile := "personal" -}}

{{- /* Check for CHEZMOI_PROFILE environment variable first */ -}}
{{- if env "CHEZMOI_PROFILE" -}}
{{-   $profile = env "CHEZMOI_PROFILE" -}}
{{- /* Auto-detect based on hostname patterns */ -}}
{{- else if contains "work" .chezmoi.hostname -}}
{{-   $profile = "work" -}}
{{- else if contains "corp" .chezmoi.hostname -}}
{{-   $profile = "work" -}}
{{- else if contains "company" .chezmoi.hostname -}}
{{-   $profile = "work" -}}
{{- end -}}

{{- /* Profile-specific settings */ -}}
{{- /* Prompt for user info on first run, or use existing values */ -}}
{{- $email := "" -}}
{{- $name := "" -}}

{{- /* Check if we already have these values (from previous chezmoi data) */ -}}
{{- if hasKey . "email" -}}
{{-   $email = .email -}}
{{- else -}}
{{-   /* Prompt for email on first deployment */ -}}
{{-   $email = promptStringOnce . "email" "Enter your email address" -}}
{{- end -}}

{{- if hasKey . "name" -}}
{{-   $name = .name -}}
{{- else -}}
{{-   /* Prompt for name on first deployment */ -}}
{{-   $name = promptStringOnce . "name" "Enter your full name" -}}
{{- end -}}

{{- /* Override with profile-specific settings if work profile */ -}}
{{- if eq $profile "work" -}}
{{-   if not (hasKey . "work_email") -}}
{{-     $email = promptStringOnce . "work_email" "Enter your work email address" -}}
{{-   else -}}
{{-     $email = .work_email -}}
{{-   end -}}
{{-   if not (hasKey . "work_name") -}}
{{-     $name = promptStringOnce . "work_name" "Enter your work name" -}}
{{-   else -}}
{{-     $name = .work_name -}}
{{-   end -}}
{{- end -}}

[data]
    profile = {{ $profile | quote }}
    email = {{ $email | quote }}
    name = {{ $name | quote }}
    isWSL = {{ $isWSL }}

{{- if eq .chezmoi.os "darwin" }}
[data.packages]
    manager = "brew"
    install_cmd = "brew install"
    update_cmd = "brew update && brew upgrade"
    search_cmd = "brew search"
{{- else if eq .chezmoi.osRelease.id "arch" }}
[data.packages]
    manager = "pacman"
    install_cmd = "sudo pacman -S"
    update_cmd = "sudo pacman -Syu"
    search_cmd = "pacman -Ss"
{{- else if or (eq .chezmoi.osRelease.id "ubuntu") (eq .chezmoi.osRelease.id "debian") }}
[data.packages]
    manager = "apt"
    install_cmd = "sudo apt install"
    update_cmd = "sudo apt update && sudo apt upgrade"
    search_cmd = "apt search"
{{- else }}
[data.packages]
    manager = "unknown"
{{- end }}

[data.paths]
{{- if eq .chezmoi.os "darwin" }}
    homebrew = "/opt/homebrew"
{{- end }}

{{- /* Theme configuration for Omarchy (Arch Linux with Hyprland) */ -}}
{{- if and (eq .chezmoi.os "linux") (eq .chezmoi.osRelease.id "arch") }}
[data.theme]
    # Current Omarchy theme name
    # Available: osaka-jade, catppuccin, everforest, gruvbox, kanagawa, nord, rose-pine, tokyo-night, etc.
    name = "catppuccin-dark"
{{- end }}
