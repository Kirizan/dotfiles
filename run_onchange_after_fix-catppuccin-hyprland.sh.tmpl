#!/bin/bash
# Fix outdated Hyprland syntax in Catppuccin theme
# This script only runs when the Catppuccin theme is updated via chezmoi
# Hash: {{ include ".chezmoiexternal.toml" | sha256sum }}

set -e

THEME_FILE="$HOME/.config/omarchy/themes/catppuccin-dark/hyprland.conf"
MARKER_FILE="$HOME/.cache/chezmoi-catppuccin-fix-applied"

# Check if the theme file exists
if [ ! -f "$THEME_FILE" ]; then
    exit 0
fi

# Check if the old syntax is present
if grep -q "no_anim on\|blur on\|ignore_alpha.*match:namespace\|rounding_power" "$THEME_FILE"; then
    echo "🔧 Catppuccin theme was updated - fixing outdated Hyprland syntax..."

    # Create a backup
    cp "$THEME_FILE" "$THEME_FILE.bak"

    # Fix the syntax
    sed -i 's/layerrule = no_anim on, match:namespace \(.*\)/layerrule = noanim, \1/g' "$THEME_FILE"
    sed -i 's/layerrule = blur on, match:namespace \(.*\)/layerrule = blur, \1/g' "$THEME_FILE"
    sed -i 's/layerrule = ignore_alpha \([0-9.]*\), match:namespace \(.*\)/layerrule = ignorealpha \1, \2/g' "$THEME_FILE"
    sed -i '/rounding_power/d' "$THEME_FILE"

    echo "✓ Fixed Hyprland syntax in Catppuccin theme"

    # Mark that we applied the fix
    mkdir -p "$(dirname "$MARKER_FILE")"
    date > "$MARKER_FILE"

    # Reload Hyprland if running
    if command -v hyprctl >/dev/null 2>&1 && [ -n "$HYPRLAND_INSTANCE_SIGNATURE" ]; then
        hyprctl reload >/dev/null 2>&1 && echo "✓ Hyprland configuration reloaded"
    fi
else
    # Check if we previously applied a fix
    if [ -f "$MARKER_FILE" ]; then
        echo "✅ GOOD NEWS: Catppuccin theme has been updated and no longer needs fixes!"
        echo "   The upstream repository appears to have fixed the syntax issues."
        echo ""
        echo "   You can remove this override script:"
        echo "   rm ~/.local/share/chezmoi/run_onchange_after_fix-catppuccin-hyprland.sh.tmpl"
        echo ""
        echo "   Then commit the change and run: chezmoi apply"

        # Remove the marker since upstream is now fixed
        rm "$MARKER_FILE"
    fi
    # If no marker exists and no old syntax, theme was never broken - stay silent
fi
