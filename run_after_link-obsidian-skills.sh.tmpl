{{- if and (eq .profile "personal") (not .isHeadless) -}}
#!/bin/bash
# Link Claude Code skills from Obsidian vault to ~/.claude/skills/
# Scans for SKILL.md files in the Claude-Skills directory and creates symlinks
# Runs after every chezmoi apply to pick up new skills

VAULT_ROOT="{{ .obsidian.vault_root }}"
SKILLS_SOURCE="$VAULT_ROOT/{{ .obsidian.primary_vault }}/Claude-Skills"
SKILLS_TARGET="$HOME/.claude/skills"

# Skip if vault or skills directory doesn't exist yet
if [ ! -d "$SKILLS_SOURCE" ]; then
    exit 0
fi

mkdir -p "$SKILLS_TARGET"

linked=0
for skill_dir in "$SKILLS_SOURCE"/*/; do
    [ -d "$skill_dir" ] || continue
    skill_name="$(basename "$skill_dir")"

    # Only link directories that contain a SKILL.md
    if [ -f "$skill_dir/SKILL.md" ]; then
        target="$SKILLS_TARGET/$skill_name"

        # Skip if already correctly linked
        if [ -L "$target" ] && [ "$(readlink "$target")" = "$skill_dir" ]; then
            continue
        fi

        # Remove existing (stale symlink or directory) and create fresh link
        rm -rf "$target"
        ln -s "$skill_dir" "$target"
        echo "  Linked skill: $skill_name"
        linked=$((linked + 1))
    fi
done

if [ "$linked" -gt 0 ]; then
    echo "Linked $linked Claude skill(s) from Obsidian vault"
fi
{{- end }}
