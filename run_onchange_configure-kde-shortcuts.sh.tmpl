{{- if and (not .isHeadless) (not .isWSL) .isArchBased -}}
#!/bin/bash
# Configure KDE Plasma 6 keyboard shortcuts to match Omarchy-style keybindings
# hash: {{ include "dot_local/bin/executable_show-keybindings" | sha256sum }}
#
# This script:
# 1. Unbinds conflicting KDE defaults
# 2. Rebinds shortcuts to Omarchy-style keys
# 3. Registers custom command shortcuts from .desktop files
# 4. Configures 9 virtual desktops in kwinrc

set -e

KGLOBALRC="$HOME/.config/kglobalshortcutsrc"
KWINRC="$HOME/.config/kwinrc"

echo "Configuring KDE shortcuts (Omarchy-style)..."

# ============================================================
# KWIN SHORTCUTS
# ============================================================

# --- Unbind conflicting KWin defaults ---

# Free Meta+W (was Toggle Overview) for close-tab
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Overview" "none,Meta+W,Toggle Overview"

# Free Meta+T (was Edit Tiles) for new-tab
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Edit Tiles" "none,Meta+T,Toggle Tiles Editor"

# Free Meta+G (was Toggle Grid View)
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Overview" "none,Meta+W,Toggle Overview"

# Free Meta+0 (was view_actual_size) for desktop 10
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "view_actual_size" "none,Meta+0,Actual Size"

# Free Meta+= and Meta++ (was view_zoom_in)
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "view_zoom_in" "none,Meta+=,Zoom In"

# Free Meta+- (was view_zoom_out)
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "view_zoom_out" "none,Meta+-,Zoom Out"

# --- Rebind Window Management ---

# Fullscreen: Meta+F
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Window Fullscreen" "Meta+F,none,Make Window Fullscreen"

# Alt+Tab only (remove Meta+Tab from window switching)
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Walk Through Windows" "Alt+Tab,Alt+Tab,Walk Through Windows"
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Walk Through Windows (Reverse)" "Alt+Shift+Tab,Alt+Shift+Tab,Walk Through Windows (Reverse)"

# --- Desktop Switching: Super+1-9, Super+0 ---

kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Switch to Desktop 1" "Meta+1,Ctrl+F1,Switch to Desktop 1"
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Switch to Desktop 2" "Meta+2,Ctrl+F2,Switch to Desktop 2"
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Switch to Desktop 3" "Meta+3,Ctrl+F3,Switch to Desktop 3"
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Switch to Desktop 4" "Meta+4,Ctrl+F4,Switch to Desktop 4"
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Switch to Desktop 5" "Meta+5,none,Switch to Desktop 5"
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Switch to Desktop 6" "Meta+6,none,Switch to Desktop 6"
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Switch to Desktop 7" "Meta+7,none,Switch to Desktop 7"
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Switch to Desktop 8" "Meta+8,none,Switch to Desktop 8"
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Switch to Desktop 9" "Meta+9,none,Switch to Desktop 9"
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Switch to Desktop 10" "Meta+0,none,Switch to Desktop 10"

# --- Desktop Navigation: Super+Tab / Super+Shift+Tab ---

kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Switch to Next Desktop" "Meta+Tab,none,Switch to Next Desktop"
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Switch to Previous Desktop" "Meta+Shift+Tab,none,Switch to Previous Desktop"

# --- Move Window to Desktop: Super+Shift+1-9, Super+Shift+0 ---

kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Window to Desktop 1" "Meta+Shift+1,none,Window to Desktop 1"
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Window to Desktop 2" "Meta+Shift+2,none,Window to Desktop 2"
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Window to Desktop 3" "Meta+Shift+3,none,Window to Desktop 3"
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Window to Desktop 4" "Meta+Shift+4,none,Window to Desktop 4"
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Window to Desktop 5" "Meta+Shift+5,none,Window to Desktop 5"
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Window to Desktop 6" "Meta+Shift+6,none,Window to Desktop 6"
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Window to Desktop 7" "Meta+Shift+7,none,Window to Desktop 7"
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Window to Desktop 8" "Meta+Shift+8,none,Window to Desktop 8"
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Window to Desktop 9" "Meta+Shift+9,none,Window to Desktop 9"
kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Window to Desktop 10" "Meta+Shift+0,none,Window to Desktop 10"

# --- Night Color Toggle ---

kwriteconfig6 --file "$KGLOBALRC" --group "kwin" --key "Toggle Night Color" "Meta+Ctrl+N,none,Toggle Night Color"

# ============================================================
# PLASMASHELL SHORTCUTS
# ============================================================

# App Launcher: add Super+Space (keep Meta and Alt+F1)
kwriteconfig6 --file "$KGLOBALRC" --group "plasmashell" --key "activate application launcher" "Meta+Space\tMeta\tAlt+F1,Meta\tAlt+F1,Activate Application Launcher"

# Free Meta+1-9 from Task Manager (needed for desktop switching)
for i in 1 2 3 4 5 6 7 8 9; do
    kwriteconfig6 --file "$KGLOBALRC" --group "plasmashell" --key "activate task manager entry $i" "none,Meta+$i,Activate Task Manager Entry $i"
done

# Free Meta+Q (was Show Activity Switcher)
kwriteconfig6 --file "$KGLOBALRC" --group "plasmashell" --key "manage activities" "none,Meta+Q,Show Activity Switcher"

# Free Meta+A (was Walk through activities)
kwriteconfig6 --file "$KGLOBALRC" --group "plasmashell" --key "next activity" "none,Meta+A,Walk through activities"
kwriteconfig6 --file "$KGLOBALRC" --group "plasmashell" --key "previous activity" "none,Meta+Shift+A,Walk through activities (Reverse)"

# Clipboard: Meta+Ctrl+V (was Meta+V)
kwriteconfig6 --file "$KGLOBALRC" --group "plasmashell" --key "clipboard_action" "Meta+Ctrl+V,Meta+V,Enable Clipboard Actions"
kwriteconfig6 --file "$KGLOBALRC" --group "plasmashell" --key "show-on-mouse-pos" "Meta+Ctrl+V,Meta+V,Show Clipboard Items at Mouse Position"

# Do Not Disturb: Meta+,
kwriteconfig6 --file "$KGLOBALRC" --group "plasmashell" --key "toggle do not disturb" "Meta+,,none,Toggle Do Not Disturb"

# ============================================================
# KSMSERVER (Lock Screen)
# ============================================================

# Lock: Meta+Ctrl+L (was Meta+L)
kwriteconfig6 --file "$KGLOBALRC" --group "ksmserver" --key "Lock Session" "Meta+Ctrl+L\tScreensaver,Meta+L\tScreensaver,Lock Session"

# ============================================================
# POWER MANAGEMENT
# ============================================================

# Free Meta+B from power profile switching
kwriteconfig6 --file "$KGLOBALRC" --group "org_kde_powerdevil" --key "Switch Power Profile" "Battery,Battery\tMeta+B,Switch Power Profile"

# ============================================================
# CUSTOM COMMAND SHORTCUTS (from .desktop files)
# ============================================================

# Terminal: Meta+Return
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-terminal.desktop" --key "_k_friendly_name" "Launch Terminal"
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-terminal.desktop" --key "_launch" "Meta+Return,none,Launch Terminal"

# Close Tab: Meta+W (sends Ctrl+W via ydotool)
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-close-tab.desktop" --key "_k_friendly_name" "Close Tab"
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-close-tab.desktop" --key "_launch" "Meta+W,none,Close Tab"

# New Tab: Meta+T (sends Ctrl+T via ydotool)
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-new-tab.desktop" --key "_k_friendly_name" "New Tab"
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-new-tab.desktop" --key "_launch" "Meta+T,none,New Tab"

# File Manager: Meta+Shift+F
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-file-manager.desktop" --key "_k_friendly_name" "File Manager"
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-file-manager.desktop" --key "_launch" "Meta+Shift+F,none,File Manager"

# Browser: Meta+Shift+B
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-browser.desktop" --key "_k_friendly_name" "Browser"
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-browser.desktop" --key "_launch" "Meta+Shift+B,none,Browser"

# Editor: Meta+Shift+N
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-editor.desktop" --key "_k_friendly_name" "Editor"
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-editor.desktop" --key "_launch" "Meta+Shift+N,none,Editor"

# System Monitor: Meta+Shift+T
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-sysmonitor.desktop" --key "_k_friendly_name" "System Monitor"
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-sysmonitor.desktop" --key "_launch" "Meta+Shift+T,none,System Monitor"

# Docker Manager: Meta+Shift+D
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-docker.desktop" --key "_k_friendly_name" "Docker Manager"
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-docker.desktop" --key "_launch" "Meta+Shift+D,none,Docker Manager"

# Music: Meta+Shift+M
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-music.desktop" --key "_k_friendly_name" "Music"
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-music.desktop" --key "_launch" "Meta+Shift+M,none,Music"

# 1Password: Meta+Shift+/
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-1password.desktop" --key "_k_friendly_name" "1Password"
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-1password.desktop" --key "_launch" "Meta+Shift+/,none,1Password"

# Keybinding Viewer: Meta+K
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-keybindings.desktop" --key "_k_friendly_name" "Keybinding Viewer"
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-keybindings.desktop" --key "_launch" "Meta+K,none,Keybinding Viewer"

# Power Menu: Meta+Escape
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-power-menu.desktop" --key "_k_friendly_name" "Power Menu"
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-power-menu.desktop" --key "_launch" "Meta+Escape,none,Power Menu"

# Screenshot Region to Clipboard: Print
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-screenshot.desktop" --key "_k_friendly_name" "Screenshot Region"
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-screenshot.desktop" --key "_launch" "Print,none,Screenshot Region"

# Screenshot Region with Editor: Meta+Print
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-screenshot-edit.desktop" --key "_k_friendly_name" "Screenshot Region Edit"
kwriteconfig6 --file "$KGLOBALRC" --group "kirizan-screenshot-edit.desktop" --key "_launch" "Meta+Print,none,Screenshot Region Edit"

# ============================================================
# KWIN WINDOW BEHAVIOR (kwinrc)
# ============================================================

# Disable edge maximize (dragging window to screen edge and holding makes it fullscreen)
# Keep edge tiling (snap to edge) enabled — that's the default
kwriteconfig6 --file "$KWINRC" --group "Windows" --key "ElectricBorderMaximize" "false"

# ============================================================
# VIRTUAL DESKTOPS (9 desktops in kwinrc)
# ============================================================

echo "Configuring 9 virtual desktops..."

# Generate UUIDs for desktops if they don't already exist
DESKTOPS_COUNT=$(kreadconfig6 --file "$KWINRC" --group "Desktops" --key "Number" 2>/dev/null || echo "1")

if [ "$DESKTOPS_COUNT" -lt 9 ]; then
    kwriteconfig6 --file "$KWINRC" --group "Desktops" --key "Number" "9"
    kwriteconfig6 --file "$KWINRC" --group "Desktops" --key "Rows" "1"

    for i in 1 2 3 4 5 6 7 8 9; do
        EXISTING_ID=$(kreadconfig6 --file "$KWINRC" --group "Desktops" --key "Id_$i" 2>/dev/null || echo "")
        if [ -z "$EXISTING_ID" ]; then
            NEW_UUID=$(cat /proc/sys/kernel/random/uuid)
            kwriteconfig6 --file "$KWINRC" --group "Desktops" --key "Id_$i" "$NEW_UUID"
        fi
        EXISTING_NAME=$(kreadconfig6 --file "$KWINRC" --group "Desktops" --key "Name_$i" 2>/dev/null || echo "")
        if [ -z "$EXISTING_NAME" ]; then
            kwriteconfig6 --file "$KWINRC" --group "Desktops" --key "Name_$i" "Desktop $i"
        fi
    done

    echo "Created 9 virtual desktops"
else
    echo "Already have $DESKTOPS_COUNT desktops configured"
fi

# ============================================================
# RELOAD SHORTCUTS
# ============================================================

echo "Reloading KDE global shortcuts..."

# Best-effort live reload - may require logout/login for full effect
if command -v dbus-send >/dev/null 2>&1; then
    # Reload kglobalaccel
    dbus-send --type=signal --dest=org.kde.KGlobalAccel /kglobalaccel org.kde.KGlobalAccel.yourShortcutsChanged 2>/dev/null || true

    # Reconfigure KWin (picks up desktop changes)
    dbus-send --dest=org.kde.KWin /KWin org.kde.KWin.reconfigure 2>/dev/null || true
fi

# Restart kglobalaccel service if available
systemctl --user restart plasma-kglobalaccel.service 2>/dev/null || true

echo ""
echo "KDE shortcuts configured successfully!"
echo "NOTE: Some changes may require logout/login to take full effect."
{{- end }}
