#!/bin/bash
{{- if and (eq .chezmoi.os "linux") (ne .profile "work") }}
# Configure passwordless sudo for personal Linux machines
# This script only runs on Linux when profile != "work"

set -e

SUDOERS_FILE="/etc/sudoers.d/{{ .chezmoi.username }}-nopasswd"
TEMP_SUDOERS="/tmp/{{ .chezmoi.username }}-nopasswd.tmp"

echo "Configuring passwordless sudo for {{ .chezmoi.username }}..."

# Create the sudoers entry
cat > "$TEMP_SUDOERS" <<EOF
# Passwordless sudo for {{ .chezmoi.username }} on personal machines
# Managed by chezmoi - do not edit manually
{{ .chezmoi.username }} ALL=(ALL) NOPASSWD: ALL
EOF

# Validate the sudoers file syntax before installing
if ! visudo -c -f "$TEMP_SUDOERS" > /dev/null 2>&1; then
    echo "ERROR: Invalid sudoers syntax. Not installing." >&2
    rm -f "$TEMP_SUDOERS"
    exit 1
fi

# Install the sudoers file if it doesn't exist or differs
if [ ! -f "$SUDOERS_FILE" ] || ! cmp -s "$TEMP_SUDOERS" "$SUDOERS_FILE"; then
    echo "Installing passwordless sudo configuration..."
    sudo install -m 0440 -o root -g root "$TEMP_SUDOERS" "$SUDOERS_FILE"
    echo "✓ Passwordless sudo configured for {{ .chezmoi.username }}"
else
    echo "✓ Passwordless sudo already configured"
fi

# Clean up
rm -f "$TEMP_SUDOERS"

{{- else }}
# Not a personal Linux machine - skipping passwordless sudo setup
{{- if eq .chezmoi.os "darwin" }}
echo "Skipping passwordless sudo: macOS does not need this configuration"
{{- else if eq .profile "work" }}
echo "Skipping passwordless sudo: work profile detected"
{{- else }}
echo "Skipping passwordless sudo: not a Linux system"
{{- end }}
exit 0
{{- end }}
