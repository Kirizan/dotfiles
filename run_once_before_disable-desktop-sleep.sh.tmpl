#!/bin/bash
# Disable automatic sleep/hibernate on desktop systems
# Only runs on Linux systems detected as desktops (no battery)

{{- if and (eq .chezmoi.os "linux") .isDesktop }}

set -e

echo "Configuring desktop power management (disabling automatic sleep/hibernate)..."

# Create systemd sleep.conf.d directory if it doesn't exist
sudo mkdir -p /etc/systemd/sleep.conf.d

# Create configuration to disable automatic suspend/hibernate
# Note: This doesn't prevent manual suspend, just automatic idle suspend
sudo tee /etc/systemd/sleep.conf.d/99-desktop-no-sleep.conf > /dev/null << 'EOF'
# Disable automatic sleep/hibernate for desktop systems
# Generated by chezmoi dotfiles
[Sleep]
AllowSuspend=no
AllowHibernation=no
AllowSuspendThenHibernate=no
AllowHybridSleep=no
EOF

# Also configure logind to not suspend on idle
sudo mkdir -p /etc/systemd/logind.conf.d
sudo tee /etc/systemd/logind.conf.d/99-desktop-no-sleep.conf > /dev/null << 'EOF'
# Disable idle suspend for desktop systems
# Generated by chezmoi dotfiles
[Login]
IdleAction=ignore
IdleActionSec=infinity
EOF

# Reload systemd configuration
sudo systemctl daemon-reload

echo "Desktop power management configured - automatic sleep/hibernate disabled."

{{- else }}
# Not a Linux desktop, skip
echo "Skipping desktop sleep configuration (not a Linux desktop system)"
{{- end }}
