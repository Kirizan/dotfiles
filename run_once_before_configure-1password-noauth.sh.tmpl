#!/bin/bash
{{- if and (eq .chezmoi.os "linux") (ne .profile "work") }}
# Allow 1Password polkit actions without authentication on personal machines.
# This mirrors the passwordless-sudo setup: the user is already logged in and
# trusted, so repeated fingerprint prompts add friction without security value.

set -e

RULES_DIR="/etc/polkit-1/rules.d"
RULES_FILE="$RULES_DIR/49-1password-noauth.rules"

# polkit JS rules (used by polkitd >= 0.106)
RULES_CONTENT='// Allow 1Password actions without re-authentication for {{ .chezmoi.username }}
// Managed by chezmoi - do not edit manually
polkit.addRule(function(action, subject) {
    if (action.id.indexOf("com.1password.1Password.") === 0 &&
        subject.user === "{{ .chezmoi.username }}") {
        return polkit.Result.YES;
    }
});'

if [ ! -d "$RULES_DIR" ]; then
    echo "ERROR: $RULES_DIR does not exist. Is polkit installed?" >&2
    exit 1
fi

TEMP_FILE="$(mktemp)"
echo "$RULES_CONTENT" > "$TEMP_FILE"

if [ ! -f "$RULES_FILE" ] || ! cmp -s "$TEMP_FILE" "$RULES_FILE"; then
    echo "Installing 1Password no-auth polkit rule..."
    sudo install -m 0644 -o root -g root "$TEMP_FILE" "$RULES_FILE"
    echo "1Password polkit rule installed at $RULES_FILE"
else
    echo "1Password polkit rule already configured"
fi

rm -f "$TEMP_FILE"
{{- else }}
echo "Skipping 1Password no-auth polkit rule: not a personal Linux machine"
exit 0
{{- end }}
