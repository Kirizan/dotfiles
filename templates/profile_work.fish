# Work profile configuration for fish shell
# This file is only sourced when chezmoi profile = "work"
# (auto-detected via hostname containing "work", "corp", or "company",
# or set manually via CHEZMOI_PROFILE=work)

# Git identity override
# set -gx GIT_AUTHOR_NAME "Your Name"
# set -gx GIT_AUTHOR_EMAIL "you@company.com"
# set -gx GIT_COMMITTER_NAME "Your Name"
# set -gx GIT_COMMITTER_EMAIL "you@company.com"

# Proxy / VPN settings
# set -gx HTTP_PROXY "http://proxy.company.com:8080"
# set -gx HTTPS_PROXY "http://proxy.company.com:8080"
# set -gx NO_PROXY "localhost,127.0.0.1,.company.com"

# AWS / Cloud profiles
# set -gx AWS_PROFILE work
# set -gx AWS_DEFAULT_REGION us-east-1

# Internal tools and paths
# fish_add_path /opt/company/bin

# Work-specific aliases
# alias vpn 'sudo openconnect vpn.company.com'
# alias jira 'open https://company.atlassian.net'
