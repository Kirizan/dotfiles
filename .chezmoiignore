.config/nvim/lazy-lock.json

# Deprecated files (no longer used)
.p10k.zsh

# macOS-specific files (ignore on Linux)
{{- if ne .chezmoi.os "darwin" }}
Brewfile
Library/
.zshrc
.zprofile
{{- end }}

# Linux-specific files (ignore on macOS)
{{- if ne .chezmoi.os "linux" }}
.bashrc
.bash_profile
{{- end }}

# Omarchy-only files (Arch Linux with Hyprland desktop)
# Ignore on macOS, Ubuntu, WSL, and any non-Omarchy system
{{- if not .isOmarchy }}
.config/hypr/
.config/waybar/
.config/mako/
.config/omarchy/
{{- end }}

# Headless systems (SSH-only servers, WSL without WSLg, etc.)
# Skip all GUI configs: terminal emulators, autostart, browser setup, GUI packages
{{- if .isHeadless }}
.config/alacritty/
.config/wezterm/
.config/autostart/
.config/vim/gvimrc
run_onchange_set-default-browser.sh.tmpl
run_once_install-personal-packages.sh.tmpl
{{- end }}

# Scripts and bin directories are handled separately
# (they're managed but not as dotfiles in home directory)

# Profile-specific ignores
# Files ending in _work.* are only for work profile
{{- if ne .profile "work" }}
*_work
*_work.*
.profile_corp
.config/work
{{- end }}

# Files ending in _personal.* are only for personal profile
{{- if ne .profile "personal" }}
*_personal
*_personal.*
.profile_personal
.config/personal
{{- end }}
