# Profile-specific ignores
# Files ending in _work.* are only for work profile
{{- if ne .profile "work" }}
*_work
*_work.*
.profile_corp
.config/work
{{- end }}

# Files ending in _personal.* are only for personal profile
{{- if ne .profile "personal" }}
*_personal
*_personal.*
.profile_personal
.config/personal
{{- end }}
