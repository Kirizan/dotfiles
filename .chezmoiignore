# Repository management files
README.md
LICENSE
Makefile
PROFILES.md
.gitignore
.git/
.claude

# Claude Code user config (contains machine-specific data: MCP servers, projects, caches)
.claude.json

# Documentation files
CLAUDE.md
HOTKEYS.md
*.org
system.org

# Temporary files
pbcopy
temp/

# Neovim plugin lockfile (machine-specific, changes frequently)
.config/nvim/lazy-lock.json

# Deprecated files (no longer used)
.p10k.zsh

# macOS-specific files (ignore on Linux)
{{- if ne .chezmoi.os "darwin" }}
.Brewfile
Library/
.zshrc
.zprofile
{{- end }}

# Linux-specific files (ignore on macOS)
{{- if ne .chezmoi.os "linux" }}
.bashrc
.bash_profile
{{- end }}

# Desktop environment configs — only deploy if the tool is installed
{{- if not (lookPath "Hyprland") }}
.config/hypr/
{{- end }}
{{- if not (lookPath "waybar") }}
.config/waybar/
{{- end }}
{{- if not (lookPath "makoctl") }}
.config/mako/
{{- end }}
{{- if not (stat (joinPath .chezmoi.homeDir ".local/share/omarchy")) }}
.config/omarchy/
{{- end }}
{{- if not (lookPath "fish") }}
.config/fish/
{{- end }}

# Headless systems (SSH-only servers, WSL without WSLg, etc.)
# Skip all GUI configs: terminal emulators, autostart, browser setup, GUI packages
{{- if .isHeadless }}
.config/alacritty/
.config/wezterm/
.config/autostart/
.config/vim/gvimrc
run_onchange_set-default-browser.sh.tmpl
run_once_install-personal-packages.sh.tmpl
{{- end }}

# Scripts and bin directories are handled separately
# (they're managed but not as dotfiles in home directory)

# Profile-specific ignores
# Files ending in _work.* are only for work profile
{{- if ne .profile "work" }}
*_work
*_work.*
.profile_corp
.config/work
{{- end }}

